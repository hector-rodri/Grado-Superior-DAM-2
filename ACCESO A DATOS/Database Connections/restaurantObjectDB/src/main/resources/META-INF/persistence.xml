<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="http://java.sun.com/xml/ns/persistence" version="2.0">
  <persistence-unit name="objectdb_restaurant" transaction-type="RESOURCE_LOCAL">
    <class>com.example.Chef</class>
    <class>com.example.Course</class>
    <class>com.example.Recipe</class>
    <class>com.example.Student</class>
    <properties>
      <property name="javax.persistence.jdbc.url"
        value="recursos/objectdb_restaurant.odb"/>
      <property name="javax.persistence.jdbc.driver" value="com.objectdb.Driver" />
    </properties>
  </persistence-unit>
</persistence>